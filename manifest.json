{
  "manifest_version": 3,
  "name": "Wanted × JobPlanet Score",
  "version": "0.4.0",
  "description": "원티드 채용공고에 잡플래닛 평점·리뷰 수와 사람인 평균연봉·영업이익을 자동으로 표시합니다.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.wanted.co.kr/*",
    "https://www.jobplanet.co.kr/*",
    "https://www.saramin.co.kr/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.wanted.co.kr/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
